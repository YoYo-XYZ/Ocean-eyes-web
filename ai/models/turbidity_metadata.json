{
  "model_name": "turbidity",
  "description": "FishAI water turbidity/clarity estimation model (YOLO classification)",
  "architecture": "Ultralytics YOLO Classifier",
  "input": {
    "shape": [
      1,
      3,
      224,
      224
    ],
    "dtype": "float32",
    "format": "NCHW",
    "preprocessing": {
      "resize": 224,
      "normalize": {
        "note": "YOLO handles normalization internally (divide by 255)"
      },
      "note": "Resize to 224x224, pass as float32 [0,1] range"
    }
  },
  "output": {
    "shape": [
      1,
      11
    ],
    "dtype": "float32",
    "description": "Class probabilities for 11 turbidity ranges",
    "postprocessing": {
      "fnu_calculation": {
        "description": "FNU = constant + sum(coefficient[class] * probability[class])",
        "formula": "FNU = -60.90 + \u03a3(coeff[i] * prob[i])",
        "coefficients": {
          "00-0.49": 61.34,
          "00.5-0.99": 61.57,
          "01-2.49": 62.48,
          "02.5-4.99": 65.53,
          "05-9.99": 67.76,
          "10-14.99": 73.91,
          "15-20.99": 77.63,
          "21-28.99": 85.64,
          "29-36.99": 94.0,
          "37-44.99": 102.85,
          "45-55": 114.32
        },
        "constant": -60.9
      },
      "top_class": "argmax of probabilities",
      "confidence": "max probability value"
    }
  },
  "classes": [
    "00-0.49",
    "00.5-0.99",
    "01-2.49",
    "02.5-4.99",
    "05-9.99",
    "10-14.99",
    "15-20.99",
    "21-28.99",
    "29-36.99",
    "37-44.99",
    "45-55"
  ],
  "num_classes": 11,
  "onnx_info": {
    "opset_version": 17,
    "batch_size": 1,
    "static_axes": "All dimensions fixed"
  },
  "usage_note": "Run once per day or on-demand. Full tank image as input.",
  "pipeline_note": "Full frame -> turbidity.onnx -> FNU value"
}